  "private": true,
  "scripts": {
    "dev": "next dev",
    "gen:images": "node tools/gen-image-manifest.mjs",
    "gen:icons": "node tools/build-icons.mjs",
    "prebuild": "node tools/gen-image-manifest.mjs",
    "build": "next build --webpack",
